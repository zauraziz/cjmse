# Neon Postgres bağlantı sətri (Vercel → Settings → Environment Variables → DATABASE_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# OJS instansiyası canlı olduqda təyin edin (göndərmə/status düymələri buraya yönləndirir)
NEXT_PUBLIC_OJS_URL=https://ojs.cjmse.adda.edu.az
NEXT_PUBLIC_SITE_URL=https://cjmse.adda.edu.az

# ---- Admin paneli (/admin) ----
# Giriş parolu (mütləq təyin edin — boş olsa giriş işləməz)
ADMIN_PASSWORD=guclu-parolunuzu-buraya-yazin
# Sessiya imzası üçün uzun təsadüfi sətir (məs. `openssl rand -hex 32`)
ADMIN_SESSION_SECRET=uzun-tesadufi-secret-buraya
